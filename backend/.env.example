# ─── Supabase Config ─────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_ID:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
